// 1
datasource db {
  provider = "sqlite"
}
 
// 2
generator client {
  provider = "prisma-client-js"
}
 

model Link {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  description String
  url         String
  comment Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  body      String
  link      Link     @relation(fields: [linkId], references: [id])
  linkId    Int
}